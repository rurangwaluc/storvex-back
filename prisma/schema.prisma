generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  directUrl         = env("DIRECT_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model PlatformUser {
  id        String       @id @default(uuid())
  email     String       @unique
  password  String
  role      PlatformRole @default(PLATFORM_ADMIN)
  createdAt DateTime     @default(now())
}
model Permission {
  id          String   @id @default(dbgenerated("(gen_random_uuid())::text")) @db.Text
  key         String   @unique @db.Text
  module      String   @db.Text
  label       String   @db.Text
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("createdAt") @db.Timestamp(6)

  rolePermissions RolePermission[]
  userPermissions UserPermission[]

  @@map("Permission")
}

model RolePermission {
  id           String   @id @default(dbgenerated("(gen_random_uuid())::text")) @db.Text
  role         UserRole
  permissionId String   @map("permission_id") @db.Text
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId])
  @@map("RolePermission")
}

model UserPermission {
  id           String   @id @default(dbgenerated("(gen_random_uuid())::text")) @db.Text
  userId       String   @map("user_id") @db.Text
  permissionId String   @map("permission_id") @db.Text
  isGranted    Boolean  @map("is_granted")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@map("UserPermission")
}

/// /////////////////////////
/// /////////////////////////
model OwnerIntent {
  id                          String            @id @default(dbgenerated("(gen_random_uuid())::text")) @db.Text
  email                       String            @db.Text
  phone                       String            @db.Text
  storeName                   String            @db.Text
  status                      OwnerIntentStatus @default(PENDING)
  expiresAt                   DateTime
  createdAt                   DateTime          @default(now())

  address                     String?           @db.Text
  convertedAt                 DateTime?
  district                    String?           @db.Text
  ownerName                   String            @db.Text
  sector                      String?           @db.Text
  shopType                    String?           @db.Text
  updatedAt                   DateTime          @default(now()) @updatedAt

  emailVerified               Boolean           @default(false)
  phoneVerified               Boolean           @default(false)
  emailVerifiedAt             DateTime?
  phoneVerifiedAt             DateTime?

  deviceId                    String?           @db.Text
  browserFingerprint          String?           @db.Text
  signupIp                    String?           @db.Text
  signupUserAgent             String?           @db.Text

  trialGrantedAt              DateTime?
  trialEligibilityCheckedAt   DateTime?
  trialBlockedReason          String?           @db.Text

  requestedPlanKey            String?           @db.Text
  requestedTierKey            String?           @db.Text
  requestedCycleKey           String?           @db.Text
  requestedStaffLimit         Int?
  requestedPriceAmount        Float?
  requestedCurrency           String?           @db.Text

  otps                        OtpCode[]
  otpDeliveryLogs             OtpDeliveryLog[]
  payments                    Payment[]
}

model Payment {
  id           String        @id @default(uuid())
  intentId     String?
  amount       Float
  currency     String        @default("RWF")
  reference    String        @unique
  status       PaymentStatus @default(PENDING)
  provider     String
  createdAt    DateTime      @default(now())
  tenantId     String?
  planKey      String?
  tierKey      String?       @db.Text
  cycleKey     String?       @db.Text
  staffLimit   Int?
  priceAmount  Float?
  purpose      String
  updatedAt    DateTime      @default(now()) @updatedAt

  intent       OwnerIntent?  @relation(fields: [intentId], references: [id])
  tenant       Tenant?       @relation(fields: [tenantId], references: [id])

  @@index([intentId])
  @@index([tenantId])
  @@index([status])
  @@index([purpose])
  @@index([planKey])
  @@index([tierKey])
  @@index([cycleKey])
}

model Tenant {
  id                           String                    @id @default(dbgenerated("(gen_random_uuid())::text")) @db.Text
  name                         String                    @db.Text
  email                        String                    @db.Text
  phone                        String                    @db.Text
  status                       TenantStatus              @default(PENDING)
  createdAt                    DateTime                  @default(now())

  logoUrl                      String?                   @db.Text
  receiptHeader                String?                   @db.Text
  receiptFooter                String?                   @db.Text
  logoKey                      String?                   @db.Text

  proformas Proforma[]

  shopType                     String?                   @db.Text
  district                     String?                   @db.Text
  sector                       String?                   @db.Text
  address                      String?                   @db.Text
  countryCode                  String                    @default("RW") @db.Text
  currencyCode                 String                    @default("RWF") @db.Text
  timezone                     String                    @default("Africa/Kigali") @db.Text
  onboardingCompleted          Boolean                   @default(false)
  onboardingCompletedAt        DateTime?

  cash_drawer_block_cash_sales Boolean                   @default(true)

  documentSettings              TenantDocumentSettings?
  documentCounter               TenantDocumentCounter?

  customers                    Customer[]
  deliveryNotes                DeliveryNote[]
  deliveryNoteCounters         DeliveryNoteCounter?
  expenses                     Expense[]
  borrowedDeals                InterStoreDeal[]          @relation("BorrowerDeals")
  suppliedDeals                InterStoreDeal[]          @relation("SupplierDeals")
  interStorePayments           InterStorePayment[]
  notifications                Notification[]
  payments                     Payment[]
  products                     Product[]
  promotions                   Promotion[]
  purchaseOrders               PurchaseOrder[]
  purchaseOrderItemSerials     PurchaseOrderItemSerial[]
  repairs                      Repair[]
  sales                        Sale[]
  salePayments                 SalePayment[]
  saleRefunds                  SaleRefund[]              @relation("TenantToSaleRefunds")
  stockAdjustments             StockAdjustment[]
  subscription                 Subscription?
  suppliers                    Supplier[]
  SupplierSupply               SupplierSupply[]
  SupplierSupplyItem           SupplierSupplyItem[]
  users                        User[]
  whatsAppAccounts             WhatsAppAccount[]
  whatsAppBroadcasts           WhatsAppBroadcast[]
  whatsAppConversations        WhatsAppConversation[]
  whatsAppMessages             WhatsAppMessage[]
  saleWarranties               SaleWarranty[]

  @@map("Tenant")
}


model TenantDocumentSettings {
  tenantId              String   @id @db.Text
  receiptPrefix         String   @default("RCT") @db.Text
  invoicePrefix         String   @default("INV") @db.Text
  warrantyPrefix        String   @default("WAR") @db.Text
  receiptPadding        Int      @default(6)
  invoicePadding        Int      @default(6)
  warrantyPadding       Int      @default(6)
  invoiceTerms          String?  @db.Text
  warrantyTerms         String?  @db.Text
  createdAt             DateTime @default(now())
  updatedAt             DateTime @default(now()) @updatedAt

  proformaPrefix        String   @default("PRF")
  proformaPadding       Int      @default(6)
  proformaTerms         String?  @db.Text
  deliveryNoteTerms     String?  @db.Text

  documentPrimaryColor  String?  @db.Text
  documentAccentColor   String?  @db.Text

  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("TenantDocumentSettings")
}

model TenantDocumentCounter {
  tenantId         String   @id @db.Text
  nextReceiptSeq   BigInt   @default(1)
  nextInvoiceSeq   BigInt   @default(1)
  nextWarrantySeq  BigInt   @default(1)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now()) @updatedAt

  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  nextProformaSeq BigInt @default(1)
  
  @@map("TenantDocumentCounter")
}

/// /////////////////////////
/// /////////////////////////
model User {
  id                         String                 @id @default(uuid())
  tenantId                   String
  name                       String
  email                      String                 @unique
  phone                      String
  password                   String
  role                       UserRole
  createdAt                  DateTime               @default(now())
  isActive                   Boolean                @default(true) @map("is_active")
  
  userPermissions UserPermission[]

  createdProformas Proforma[] @relation("ProformaCreatedBy")


  auditLogs                  AuditLog[]
  createdDeliveryNotes       DeliveryNote[]
  approvedExpenses           Expense[]              @relation("ApprovedExpenses")
  createdExpenses            Expense[]              @relation("CreatedExpenses")
  receivedInterStorePayments InterStorePayment[]    @relation("ReceivedInterStorePayments")
  createdNotifications       Notification[]         @relation("NotificationsCreated")
  receivedNotifications      Notification[]         @relation("NotificationsReceived")
  promotions                 Promotion[]
  purchaseOrders             PurchaseOrder[]
  repairs                    Repair[]               @relation("TechnicianRepairs")
  sales                      Sale[]                 @relation("CashierSales")
  saleRefundsCreated         SaleRefund[]           @relation("UserToSaleRefunds")
  receivedSalePayments       SalePayment[]          @relation("ReceivedSalePayments")
  stockAdjustments           StockAdjustment[]
  tenant                     Tenant                 @relation(fields: [tenantId], references: [id])
  whatsAppBroadcasts         WhatsAppBroadcast[]
  assignedConversations      WhatsAppConversation[]
  whatsAppMessages           WhatsAppMessage[]
  saleWarranties             SaleWarranty[]

  @@index([tenantId])
  @@index([tenantId, id])
  @@map("User")
}


model Subscription {
  id                  String                  @id @default(dbgenerated("(gen_random_uuid())::text")) @db.Text
  tenantId            String                  @unique @db.Text
  status              SubscriptionStatus
  accessMode          SubscriptionAccessMode  @default(ACTIVE)

  planKey             String?                 @db.Text
  tierKey             String?                 @db.Text
  cycleKey            String?                 @db.Text
  staffLimit          Int?
  priceAmount         Float?
  currency            String?                 @db.Text

  startDate           DateTime
  endDate             DateTime
  trialStartDate      DateTime?
  trialEndDate        DateTime?
  graceEndDate        DateTime?
  readOnlySince       DateTime?
  lastPaymentAt       DateTime?
  renewedAt           DateTime?
  createdAt           DateTime                @default(now())

  trialConsumed       Boolean                 @default(false)
  trialSourceIntentId String?                 @db.Text
  nextPlanKey         String?                 @db.Text

  tenant              Tenant                  @relation(fields: [tenantId], references: [id])

  @@index([status])
  @@index([accessMode])
  @@index([planKey])
  @@index([tierKey])
  @@index([cycleKey])
}

model Product {
  id                        String                    @id @default(uuid())
  tenantId                  String
  name                      String
  sku                       String?
  serial                    String?
  costPrice                 Float
  sellPrice                 Float
  stockQty                  Int
  createdAt                 DateTime                  @default(now())
  isActive                  Boolean                   @default(true)
  brand                     String?
  category                  String?
  subcategory               String?
  subcategoryOther          String?
  minStockLevel             Int?
  barcode                   String?
  location                  String?
  notes                     String?
  refundItems               SaleRefundItem[]          @relation("ProductToRefundItems")
  supplierName              String?
  supplierId                String?
  deliveryNoteItems         DeliveryNoteItem[]
  deals                     InterStoreDeal[]          @relation("ProductDeals")
  receivedInInterStoreDeals InterStoreDeal[]          @relation("ReceivedProduct")
  supplier                  Supplier?                 @relation(fields: [supplierId], references: [id])
  tenant                    Tenant                    @relation(fields: [tenantId], references: [id])
  promotions                Promotion[]
  purchaseOrderItems        PurchaseOrderItem[]
  purchaseOrderItemSerials  PurchaseOrderItemSerial[]
  saleItems                 SaleItem[]
  stockAdjustments          StockAdjustment[]
  SupplierSupplyItem        SupplierSupplyItem[]

  proformaItems ProformaItem[]

  @@index([tenantId, supplierId])
  @@index([tenantId])
  @@index([tenantId, category])
  @@index([tenantId, subcategory])
  @@index([tenantId, name])
  @@index([tenantId, barcode])
  @@index([tenantId, brand])
  @@index([tenantId, supplierName])
}

model Customer {
  id                    String                 @id @default(uuid())
  tenantId              String
  name                  String
  phone                 String
  email                 String?
  address               String?
  tinNumber             String?
  idNumber              String?
  notes                 String?
  isActive              Boolean                @default(true)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @default(now()) @updatedAt
  whatsappOptIn         Boolean                @default(false)

  tenant                Tenant                 @relation(fields: [tenantId], references: [id])
  repairs               Repair[]
  sales                 Sale[]
  whatsAppConversations WhatsAppConversation[]

  proformas Proforma[]

  @@unique([tenantId, phone])
  @@index([tenantId])
  @@index([tenantId, name])
  @@index([tenantId, phone])
  @@index([tenantId, isActive])
  @@index([tenantId, tinNumber])
  @@index([tenantId, idNumber])
}

model Sale {
  id         String            @id @default(uuid())
  tenantId   String
  cashierId  String
  customerId String?
  total      Float
  createdAt  DateTime          @default(now())
  amountPaid Float             @default(0)
  balanceDue Float             @default(0)
  dueDate    DateTime?
  saleType   SaleType          @default(CASH)
  status     SalePaymentStatus @default(PAID)

  // draft lifecycle
  isDraft     Boolean   @default(false)
  draftSource String?
  finalizedAt DateTime?

  // cancel/void support
  isCancelled   Boolean   @default(false)
  cancelledAt   DateTime?
  cancelledById String?
  cancelNote    String?

  // refund summary
  refundedTotal Float @default(0)

  deliveryNotes DeliveryNote[]
  cashier       User           @relation("CashierSales", fields: [cashierId], references: [id])
  customer      Customer?      @relation(fields: [customerId], references: [id])
  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  items         SaleItem[]
  payments      SalePayment[]  @relation("SalePayments")
  refunds       SaleRefund[]   @relation("SaleToRefunds")
  warranties    SaleWarranty[]

  receiptNumber String?
  invoiceNumber String?

  conversationId String?
  conversation   WhatsAppConversation? @relation(fields: [conversationId], references: [id])
  @@index([conversationId])

  @@index([tenantId])
  @@index([tenantId, isDraft])
  @@index([tenantId, draftSource])
  @@index([saleType])
  @@index([status])
  @@index([dueDate])
  @@index([isCancelled])
}

model SaleItem {
  id                String             @id @default(uuid())
  saleId            String
  productId         String
  quantity          Int
  price             Float
  product           Product            @relation(fields: [productId], references: [id])
  sale              Sale               @relation(fields: [saleId], references: [id])
  saleWarrantyUnits SaleWarrantyUnit[]
}

model SalePayment {
  id           String            @id @default(uuid())
  saleId       String
  tenantId     String
  receivedById String?
  amount       Float
  method       SalePaymentMethod @default(CASH)
  note         String?
  createdAt    DateTime          @default(now())
  receivedBy   User?             @relation("ReceivedSalePayments", fields: [receivedById], references: [id])
  sale         Sale              @relation("SalePayments", fields: [saleId], references: [id])
  tenant       Tenant            @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, note])
  @@index([saleId])
  @@index([tenantId])
  @@index([receivedById])
}

model Proforma {
  id               String          @id @default(cuid())
  tenantId         String
  customerId       String?
  createdById      String?

  number           String
  status           ProformaStatus  @default(DRAFT)

  customerName     String
  customerPhone    String?
  customerEmail    String?
  customerAddress  String?

  subtotal         Float           @default(0)
  total            Float           @default(0)
  currency         String          @default("RWF")

  validUntil       DateTime?
  preparedBy       String?
  reference        String?
  notes            String?

  convertedToSaleId String?
  convertedAt      DateTime?

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  tenant           Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer         Customer?       @relation(fields: [customerId], references: [id], onDelete: SetNull)
  createdBy        User?           @relation("ProformaCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  items            ProformaItem[]

  @@unique([tenantId, number])
  @@index([tenantId, status, createdAt])
  @@index([tenantId, customerName])
  @@index([tenantId, customerPhone])
  @@index([tenantId, validUntil])
  @@index([tenantId, convertedToSaleId])
}

model ProformaItem {
  id           String    @id @default(cuid())
  proformaId   String
  productId    String?

  productName  String
  serial       String?
  quantity     Int
  unitPrice    Float
  total        Float

  createdAt    DateTime  @default(now())

  proforma     Proforma  @relation(fields: [proformaId], references: [id], onDelete: Cascade)
  product      Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([proformaId, createdAt])
  @@index([productId])
}

model SaleRefund {
  id          String @id @default(dbgenerated("(gen_random_uuid())::text")) @db.Text
  saleId      String @map("sale_id") @db.Text
  tenantId    String @map("tenant_id") @db.Text
  createdById String @map("created_by_id") @db.Text

  // ✅ these exist in DB (you showed them)
  total  Float   @map("total")
  method String  @map("method") @db.Text // keep String because DB column is TEXT (not a Postgres enum)
  note   String? @map("note") @db.Text

  reason    String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  sale      Sale   @relation(fields: [saleId], references: [id], name: "SaleToRefunds")
  tenant    Tenant @relation(fields: [tenantId], references: [id], name: "TenantToSaleRefunds")
  createdBy User   @relation(fields: [createdById], references: [id], name: "UserToSaleRefunds")

  items SaleRefundItem[] @relation("RefundToItems")

  @@index([saleId])
  @@index([tenantId])
  @@index([createdById])
  @@map("SaleRefund")
}

model SaleRefundItem {
  id        String @id @default(dbgenerated("(gen_random_uuid())::text")) @db.Text
  refundId  String @map("refund_id") @db.Text
  productId String @map("product_id") @db.Text
  quantity  Int    @map("quantity")
  price     Float  @map("price")

  refund  SaleRefund @relation(fields: [refundId], references: [id], name: "RefundToItems")
  product Product    @relation(fields: [productId], references: [id], name: "ProductToRefundItems")

  @@index([refundId])
  @@index([productId])
  @@map("SaleRefundItem")
}

model Repair {
  id           String       @id @default(uuid())
  tenantId     String
  customerId   String
  technicianId String?
  device       String
  serial       String?
  issue        String
  status       RepairStatus
  warrantyEnd  DateTime?
  createdAt    DateTime     @default(now())
  customer     Customer     @relation(fields: [customerId], references: [id])
  technician   User?        @relation("TechnicianRepairs", fields: [technicianId], references: [id])
  tenant       Tenant       @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model Expense {
  id           String          @id @default(cuid())
  title        String
  notes        String?
  status       String          @default("PENDING")
  createdAt    DateTime        @default(now())
  approvedAt   DateTime?
  tenantId     String
  createdById  String
  approvedById String?
  category     ExpenseCategory
  amount       Float
  approvedBy   User?           @relation("ApprovedExpenses", fields: [approvedById], references: [id])
  createdBy    User            @relation("CreatedExpenses", fields: [createdById], references: [id])
  tenant       Tenant          @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model InterStoreDeal {
  id                    String               @id @default(uuid())
  supplierTenantId      String?
  borrowerTenantId      String
  productId             String?
  serial                String
  agreedPrice           Float
  status                InterStoreDealStatus @default(BORROWED)
  borrowedAt            DateTime             @default(now())
  soldAt                DateTime?
  returnedAt            DateTime?
  paidAt                DateTime?
  notes                 String?
  createdAt             DateTime             @default(now())
  externalSupplierName  String?
  externalSupplierPhone String?
  productName           String
  receivedAt            DateTime?
  receivedProductId     String?
  soldPrice             Float?
  paidAmount            Float?
  paymentMethod         String?
  saleId                String?
  resellerName          String
  resellerPhone         String
  resellerStore         String?
  resellerWorkplace     String?
  resellerDistrict      String?
  resellerSector        String?
  resellerAddress       String?
  resellerNationalId    String?
  productCategory       String?
  productColor          String?
  quantity              Int                  @default(1)
  soldQuantity          Int                  @default(0)
  returnedQuantity      Int                  @default(0)
  dueDate               DateTime?
  takenAt               DateTime?
  borrowerTenant        Tenant               @relation("BorrowerDeals", fields: [borrowerTenantId], references: [id])
  product               Product?             @relation("ProductDeals", fields: [productId], references: [id])
  receivedProduct       Product?             @relation("ReceivedProduct", fields: [receivedProductId], references: [id])
  supplierTenant        Tenant?              @relation("SupplierDeals", fields: [supplierTenantId], references: [id])
  payments              InterStorePayment[]

  @@index([borrowerTenantId])
  @@index([supplierTenantId])
  @@index([status])
  @@index([receivedProductId])
  @@index([resellerPhone])
  @@index([serial])
}

model InterStorePayment {
  id           String                  @id @default(uuid())
  dealId       String
  tenantId     String
  receivedById String?
  amount       Float
  method       InterStorePaymentMethod @default(CASH)
  note         String?
  createdAt    DateTime                @default(now())
  deal         InterStoreDeal          @relation(fields: [dealId], references: [id])
  receivedBy   User?                   @relation("ReceivedInterStorePayments", fields: [receivedById], references: [id])
  tenant       Tenant                  @relation(fields: [tenantId], references: [id])

  @@index([dealId])
  @@index([tenantId])
  @@index([receivedById])
}

model AuditLog {
  id        String      @id @default(uuid())
  tenantId  String
  entityId  String?
  createdAt DateTime    @default(now())
  userId    String?
  metadata  Json?
  action    AuditAction
  entity    AuditEntity
  user      User?       @relation(fields: [userId], references: [id])

  @@index([tenantId, createdAt])
  @@index([tenantId, entity, createdAt])
  @@index([tenantId, action, createdAt])
}

model WhatsAppAccount {
  id                 String                 @id @default(uuid())
  tenantId           String
  phoneNumber        String
  businessName       String?
  phoneNumberId      String?                @unique
  wabaId             String?
  accessToken        String?
  webhookVerifyToken String?
  appSecret          String?
  isActive           Boolean                @default(true)
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  tenant             Tenant                 @relation(fields: [tenantId], references: [id])
  broadcasts         WhatsAppBroadcast[]
  conversations      WhatsAppConversation[] @relation("AccountConversations")
  whatsAppMessages   WhatsAppMessage[]

  @@unique([tenantId, phoneNumber])
  @@index([tenantId])
}

model WhatsAppConversation {
  id           String             @id @default(uuid())
  tenantId     String
  accountId    String
  customerId   String?
  phone        String
  status       ConversationStatus @default(OPEN)
  assignedToId String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  account      WhatsAppAccount    @relation("AccountConversations", fields: [accountId], references: [id])
  assignedTo   User?              @relation(fields: [assignedToId], references: [id])
  customer     Customer?          @relation(fields: [customerId], references: [id])
  tenant       Tenant             @relation(fields: [tenantId], references: [id])
  messages     WhatsAppMessage[]
  sales Sale[]

  @@index([tenantId])
  @@index([phone])
  @@index([accountId])
  @@index([tenantId, status])
}

model WhatsAppMessage {
  id             String               @id @default(uuid())
  conversationId String
  tenantId       String
  accountId      String?
  broadcastId    String?
  direction      WhatsAppDirection
  type           WhatsAppMessageType
  textContent    String?
  mediaUrl       String?
  messageId      String?              @unique
  sentById       String?
  createdAt      DateTime             @default(now())
  account        WhatsAppAccount?     @relation(fields: [accountId], references: [id])
  broadcast      WhatsAppBroadcast?   @relation(fields: [broadcastId], references: [id])
  conversation   WhatsAppConversation @relation(fields: [conversationId], references: [id])
  sentBy         User?                @relation(fields: [sentById], references: [id])
  tenant         Tenant               @relation(fields: [tenantId], references: [id])

  @@index([conversationId])
  @@index([tenantId])
  @@index([accountId])
  @@index([broadcastId])
}

model Promotion {
  id          String              @id @default(uuid())
  tenantId    String
  title       String
  message     String
  productId   String?
  createdById String
